From 96710cb16eb324935d73f44463c0b27b6110ad61 Mon Sep 17 00:00:00 2001
From: ekane bryan <ekanebryan5@gmail.com>
Date: Thu, 23 Jul 2026 07:54:48 +0000
Subject: [PATCH] fix(datepicker): time column overflow past rounded corners

The .react-datepicker wrapper had overflow:hidden WITHOUT !important,
so react-datepicker's own CSS overrode it on desktop, letting the time
column's square edges bleed past the parent's rounded bottom-right corner.

Fix: add !important to .react-datepicker overflow:hidden, and add
overflow:hidden !important to .react-datepicker__time-container so the
time column clips within the parent's border-radius.
---
 Frontend/src/shared/styles/global.css | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/Frontend/src/shared/styles/global.css b/Frontend/src/shared/styles/global.css
index 658aefe..fd9ecf8 100644
--- a/Frontend/src/shared/styles/global.css
+++ b/Frontend/src/shared/styles/global.css
@@ -77,10 +77,14 @@ select {
 .react-datepicker {
   border: 1px solid #e2e8f0 !important;
   border-radius: 1rem !important;
-  overflow: hidden;
+  overflow: hidden !important;
   font-family: inherit !important;
 }
 
+.react-datepicker__time-container {
+  overflow: hidden !important;
+}
+
 .react-datepicker__header {
   background: #f8fafc !important;
   border-bottom: 1px solid #e2e8f0 !important;
-- 
2.47.3

