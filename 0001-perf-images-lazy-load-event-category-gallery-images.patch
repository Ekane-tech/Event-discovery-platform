From e8dfb95c191c7115e1280a37bd3a4e838b2ea1f4 Mon Sep 17 00:00:00 2001
From: ekane bryan <ekanebryan5@gmail.com>
Date: Thu, 23 Jul 2026 04:07:46 +0000
Subject: [PATCH] perf(images): lazy-load event/category/gallery images

- EventCard, RecommendedEventCard, HomePage category cards: convert the
  cover from a CSS background-image to a real <img loading='lazy'> so the
  browser defers off-screen card images (the most-loaded images in the app).
- Add loading='lazy' decoding='async' to: shared Avatar (all avatars),
  OrganizerEventCard cover, event-details gallery images.
- Event-details hero <img> stays eager (it is the LCP element).
Cuts the data downloaded on image-heavy grids (home/browse/search/
bookmarks/recommendations) by not loading off-screen images up front.
---
 Frontend/src/features/events/components/EventCard.jsx         | 2 +-
 .../src/features/events/components/OrganizerEventCard.jsx     | 2 +-
 Frontend/src/features/events/pages/EventDetailsPage.jsx       | 4 ++--
 Frontend/src/features/events/pages/HomePage.jsx               | 2 +-
 .../recommendations/components/RecommendedEventCard.jsx       | 2 +-
 Frontend/src/shared/components/ui/Avatar.jsx                  | 2 ++
 6 files changed, 8 insertions(+), 6 deletions(-)

diff --git a/Frontend/src/features/events/components/EventCard.jsx b/Frontend/src/features/events/components/EventCard.jsx
index 5703d1f..d68a7af 100644
--- a/Frontend/src/features/events/components/EventCard.jsx
+++ b/Frontend/src/features/events/components/EventCard.jsx
@@ -37,7 +37,7 @@ export default function EventCard({ event }) {
 
   return (
     <Link to={`/events/${event.id}`} state={{ from: `${location.pathname}${location.search}` }} className="group relative flex h-full min-h-[360px] flex-col overflow-hidden rounded-xl bg-slate-900 shadow-sm ring-1 ring-slate-200 transition duration-300 hover:-translate-y-1 hover:shadow-2xl">
-      <div className="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105" style={{ backgroundImage: `url(${bg})` }} />
+      <img src={bg} alt={event.title} loading="lazy" decoding="async" className="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105" />
       <div className="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-950/35 to-slate-950/5" />
       <div className="absolute right-4 top-4 z-10 flex gap-2">
         {!lifecycle.isPast && lifecycle.registrationDeadlineUrgent && (
