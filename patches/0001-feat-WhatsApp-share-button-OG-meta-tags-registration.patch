+++ b/Frontend/index.html
@@ -5,7 +5,16 @@
     <meta name="viewport" content="width=device-width, initial-scale=1.0" />
     <link rel="icon" type="image/png" href="/applogo.png" />
     <link rel="apple-touch-icon" href="/applogo.png" />
-    <meta name="description" content="Mboa Events 237 — Your gateway to Cameroon’s events." />
+    <meta name="description" content="Mboa Events 237 — Your gateway to Cameroon's events. Discover, register, and experience events across Cameroon." />
+    <meta property="og:title" content="Mboa Events 237 — Your gateway to Cameroon's events" />
+    <meta property="og:description" content="Discover, register, and experience events across Cameroon." />
+    <meta property="og:type" content="website" />
+    <meta property="og:image" content="/applogo.png" />
