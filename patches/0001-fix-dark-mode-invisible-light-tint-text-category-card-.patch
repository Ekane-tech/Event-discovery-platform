From 57f33511b63ffe56d808d3a602bdc42717a6f01a Mon Sep 17 00:00:00 2001
From: ekane bryan <ekanebryan5@gmail.com>
Date: Wed, 22 Jul 2026 18:13:36 +0000
Subject: [PATCH] fix(dark mode): invisible light-tint text + category card
 contrast

- Category cards (home): description now text-white and the image overlay
  is darkened (from-slate-950/85) so white text is legible in both modes.
- Dark-mode CSS: light-tint accent/slate TEXT classes (text-slate-50,
  text-blue-100, text-purple-100, text-pink-100, text-amber-100, ...) are
  now kept LIGHT in dark mode. They sit on dark/image backgrounds; the
  earlier token remap had turned them dark (invisible). Teal tints were
  already covered by the existing .dark .text-teal-* block.
---
 .../src/features/events/pages/HomePage.jsx    |  4 ++--
 Frontend/src/index.css                        | 24 +++++++++++++++++++
 2 files changed, 26 insertions(+), 2 deletions(-)

diff --git a/Frontend/src/features/events/pages/HomePage.jsx b/Frontend/src/features/events/pages/HomePage.jsx
index 1f00648..a44e343 100644
--- a/Frontend/src/features/events/pages/HomePage.jsx
+++ b/Frontend/src/features/events/pages/HomePage.jsx
@@ -121,10 +121,10 @@ export default function HomePage()  {
               <StaggerItem key={category.id}>
               <Link to={`/events?category_id=${category.id}`} className="group relative block min-h-47.5 overflow-hidden rounded-xl bg-slate-900 p-5 text-white shadow-sm ring-1 ring-slate-200 transition hover:-translate-y-1 hover:shadow-xl">
                 <div className="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105" style={{ backgroundImage: `url(${category.image_url || '/hero-events.svg'})` }} />
-                <div className="absolute inset-0 bg-linear-to-t from-slate-950/30 via-slate-950/10 to-transparent" />
+                <div className="absolute inset-0 bg-linear-to-t from-slate-950/85 via-slate-950/45 to-slate-950/5" />
                 <div className="relative flex min-h-37.5 flex-col justify-end overflow-hidden">
                 <h3 className="text-xl max-md:text-base font-black drop-shadow-sm truncate w-full" title={category.name}>{category.name}</h3>
-                  <p className="mt-1 line-clamp-2 text-sm leading-6 text-slate-50 drop-shadow-sm">{category.description}</p>
+                  <p className="mt-1 line-clamp-2 text-sm leading-6 text-white drop-shadow-sm">{category.description}</p>
                 </div>
               </Link>
               </StaggerItem>
diff --git a/Frontend/src/index.css b/Frontend/src/index.css
index af4d6a7..7b756b1 100644
--- a/Frontend/src/index.css
+++ b/Frontend/src/index.css
@@ -88,6 +88,30 @@ body {
 .dark .text-slate-300 { color: #cbd5e1; }
 .dark .text-slate-200 { color: #cdd8e6; }
 .dark .text-slate-100 { color: #d7deea; }
+.dark .text-slate-50  { color: #f8fafc; }
+
+/* Light-tint accent TEXT must stay light in dark mode (it sits on dark/image
+   backgrounds). The token remap above darkens bg-* usages of these tints; these
+   rules keep the text-* versions light so labels stay legible. (Teal tints are
+   already handled by the .dark .text-teal-* block below.) */
+.dark .text-red-50    { color: #fecaca; }
+.dark .text-red-100   { color: #fecaca; }
+.dark .text-green-50  { color: #bbf7d0; }
+.dark .text-green-100 { color: #bbf7d0; }
+.dark .text-blue-50   { color: #bfdbfe; }
+.dark .text-blue-100  { color: #bfdbfe; }
+.dark .text-amber-50  { color: #fde68a; }
+.dark .text-amber-100 { color: #fde68a; }
+.dark .text-yellow-50 { color: #fef08a; }
+.dark .text-yellow-100{ color: #fef08a; }
+.dark .text-purple-50 { color: #e9d5ff; }
+.dark .text-purple-100{ color: #e9d5ff; }
+.dark .text-pink-50   { color: #fbcfe8; }
+.dark .text-pink-100  { color: #fbcfe8; }
+.dark .text-indigo-50 { color: #c7d2fe; }
+.dark .text-rose-50   { color: #ffcdd2; }
+.dark .text-emerald-50{ color: #a7f3d0; }
+.dark .text-orange-50 { color: #fed7aa; }
 .dark .\!text-slate-950 { color: #f6f8fb !important; }
 
 /* keep labels on coloured buttons / badges / hero text white */
-- 
2.47.3

