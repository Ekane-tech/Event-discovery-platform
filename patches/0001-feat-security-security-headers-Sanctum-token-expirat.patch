From d4e608d7f1a7d996bedf8e1710d0bdd15cfcc4cd Mon Sep 17 00:00:00 2001
From: ekane bryan <ekanebryan5@gmail.com>
Date: Thu, 23 Jul 2026 07:35:54 +0000
Subject: [PATCH] feat(security): security headers + Sanctum token expiration
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- SecurityHeaders middleware: adds X-Content-Type-Options, X-Frame-Options,
  Referrer-Policy, Permissions-Policy, HSTS to every API response.
- Sanctum token expiration: tokens now expire after 7 days of inactivity
  (configurable via SANCTUM_TTL env var). Previously tokens never expired.
- XSS audit: no dangerouslySetInnerHTML found — React auto-escapes all UGC.
- Rate limiting: already comprehensive (login 5/min, register 3/min, etc.).
- CORS: already restricted to localhost + Vercel domain.
---
 .../app/Http/Middleware/SecurityHeaders.php   | 26 +++++++++++++++++++
 Backend/bootstrap/app.php                     |  1 +
 Backend/config/sanctum.php                    |  2 +-
 3 files changed, 28 insertions(+), 1 deletion(-)
 create mode 100644 Backend/app/Http/Middleware/SecurityHeaders.php

diff --git a/Backend/app/Http/Middleware/SecurityHeaders.php b/Backend/app/Http/Middleware/SecurityHeaders.php
new file mode 100644
index 0000000..1cc7972
--- /dev/null
+++ b/Backend/app/Http/Middleware/SecurityHeaders.php
@@ -0,0 +1,26 @@
+<?php
+
+namespace App\Http\Middleware;
+
+use Closure;
+use Illuminate\Http\Request;
+use Symfony\Component\HttpFoundation\Response;
+
+/**
+ * Adds standard security headers to every API response.
+ */
+class SecurityHeaders
+{
+    public function handle(Request $request, Closure $next): Response
+    {
+        $response = $next($request);
+
+        $response->headers->set('X-Content-Type-Options', 'nosniff');
+        $response->headers->set('X-Frame-Options', 'DENY');
+        $response->headers->set('Referrer-Policy', 'strict-origin-when-cross-origin');
+        $response->headers->set('Permissions-Policy', 'camera=(), microphone=(), geolocation=()');
+        $response->headers->set('Strict-Transport-Security', 'max-age=31536000; includeSubDomains');
+
+        return $response;
+    }
+}
diff --git a/Backend/bootstrap/app.php b/Backend/bootstrap/app.php
index 2b70c2b..98b1d90 100644
--- a/Backend/bootstrap/app.php
+++ b/Backend/bootstrap/app.php
@@ -12,6 +12,7 @@
         health: '/up',
     )
     ->withMiddleware(function (Middleware $middleware): void {
+        $middleware->append(\App\Http\Middleware\SecurityHeaders::class);
         $middleware->alias([
             'role' => \App\Http\Middleware\EnsureUserHasRole::class,
         ]);
diff --git a/Backend/config/sanctum.php b/Backend/config/sanctum.php
index a547849..28f7f48 100644
--- a/Backend/config/sanctum.php
+++ b/Backend/config/sanctum.php
@@ -49,7 +49,7 @@
     |
     */
 
-    'expiration' => null,
+    'expiration' => env('SANCTUM_TTL', 7 * 24 * 60),
 
     /*
     |--------------------------------------------------------------------------
