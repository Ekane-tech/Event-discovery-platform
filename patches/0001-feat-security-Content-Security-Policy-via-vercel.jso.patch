From 4c31621d0d7922d0df550ed6e4a3ffa97850d708 Mon Sep 17 00:00:00 2001
From: ekane bryan <ekanebryan5@gmail.com>
Date: Thu, 23 Jul 2026 08:35:29 +0000
Subject: [PATCH] feat(security): Content-Security-Policy via vercel.json +
 external theme script
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

CSP (set on the Vercel-served HTML page):
- script-src 'self' — scripts only from same origin (no inline, no eval)
- style-src 'self' 'unsafe-inline' — Tailwind + framer-motion inline styles
- img-src 'self' data: blob: OSM tiles + Railway backend images
- connect-src 'self' Nominatim + Railway API
- frame-ancestors 'none', object-src 'none', base-uri 'self', form-action 'self'

Also moved the no-flash inline theme script from index.html to an
external /theme-init.js file so CSP script-src 'self' can be enforced
(inline scripts would require 'unsafe-inline' which defeats CSP).

Added X-Frame-Options, X-Content-Type-Options, Referrer-Policy,
Permissions-Policy, HSTS to Vercel headers (frontend page didn't have
these before — only the Laravel API had them via SecurityHeaders middleware).
---
 Frontend/index.html           | 13 +------------
 Frontend/public/theme-init.js | 12 ++++++++++++
 Frontend/vercel.json          | 33 ++++++++++++++++++++++++++++++++-
 3 files changed, 45 insertions(+), 13 deletions(-)
 create mode 100644 Frontend/public/theme-init.js

diff --git a/Frontend/index.html b/Frontend/index.html
index f4a0c50..c0c8900 100644
--- a/Frontend/index.html
+++ b/Frontend/index.html
@@ -7,18 +7,7 @@
     <link rel="apple-touch-icon" href="/applogo.png" />
     <meta name="description" content="Mboa Events 237 — Your gateway to Cameroon’s events." />
     <title>Mboa Events 237</title>
-    <script>
-      // Apply the saved theme before paint to avoid a flash of the wrong theme.
-      (function () {
-        try {
-          var saved = localStorage.getItem('theme')
-          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
-          var theme = saved === 'light' || saved === 'dark' ? saved : (prefersDark ? 'dark' : 'light')
-          document.documentElement.classList.add(theme)
-          document.documentElement.style.colorScheme = theme
-        } catch (e) {}
-      })()
-    </script>
+    <script src="/theme-init.js"></script>
   </head>
   <body>
     <div id="root"></div>
diff --git a/Frontend/public/theme-init.js b/Frontend/public/theme-init.js
new file mode 100644
index 0000000..c334afd
--- /dev/null
+++ b/Frontend/public/theme-init.js
@@ -0,0 +1,12 @@
+// Apply the saved theme before paint to avoid a flash of the wrong theme.
+// Extracted to an external file so CSP script-src 'self' can be enforced
+// (inline scripts would require 'unsafe-inline' which defeats CSP).
+(function () {
+  try {
+    var saved = localStorage.getItem('theme')
+    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
+    var theme = saved === 'light' || saved === 'dark' ? saved : (prefersDark ? 'dark' : 'light')
+    document.documentElement.classList.add(theme)
+    document.documentElement.style.colorScheme = theme
+  } catch (e) {}
+})()
diff --git a/Frontend/vercel.json b/Frontend/vercel.json
index 29c0269..490e56c 100644
--- a/Frontend/vercel.json
+++ b/Frontend/vercel.json
@@ -1,8 +1,39 @@
 {
+  "headers": [
+    {
+      "source": "/(.*)",
+      "headers": [
+        {
+          "key": "Content-Security-Policy",
+          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.tile.openstreetmap.org https://*.up.railway.app; font-src 'self' data:; connect-src 'self' https://nominatim.openstreetmap.org https://*.up.railway.app; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none';"
+        },
+        {
+          "key": "X-Content-Type-Options",
+          "value": "nosniff"
+        },
+        {
+          "key": "X-Frame-Options",
+          "value": "DENY"
+        },
+        {
+          "key": "Referrer-Policy",
+          "value": "strict-origin-when-cross-origin"
+        },
+        {
+          "key": "Permissions-Policy",
+          "value": "camera=(), microphone=(), geolocation=()"
+        },
+        {
+          "key": "Strict-Transport-Security",
+          "value": "max-age=31536000; includeSubDomains"
+        }
+      ]
+    }
+  ],
   "rewrites": [
     {
       "source": "/(.*)",
       "destination": "/index.html"
     }
   ]
-}
\ No newline at end of file
+}
