From 136e041193700581dadaa42e980ba3dfa31534f5 Mon Sep 17 00:00:00 2001
From: Mboa Dev <dev@mboa237.local>
Date: Fri, 24 Jul 2026 03:43:01 +0000
Subject: [PATCH] fix(event details): declare isSoldOut before use in
 EventActionPanel

EventActionPanel referenced isSoldOut inside showPurchaseForm before its
const declaration, throwing ReferenceError: Cannot access 'isSoldOut'
before initialization and crashing the event details page (ErrorBoundary
showed 'something went wrong'). This was the real cause of the prod error
'Cannot access Z before initialization' (Z = minified isSoldOut); the
earlier PrefetchLink removal did not address it.

Move the capacity-derived consts (maxCapacity, confirmedRegistrations,
remaining, isSoldOut, isLowCapacity) above showPurchaseForm.
---
 .../src/features/events/components/EventActionPanel.jsx    | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/Frontend/src/features/events/components/EventActionPanel.jsx b/Frontend/src/features/events/components/EventActionPanel.jsx
index 2fe8c0e..28567c2 100644
--- a/Frontend/src/features/events/components/EventActionPanel.jsx
+++ b/Frontend/src/features/events/components/EventActionPanel.jsx
@@ -43,15 +43,14 @@ export default function EventActionPanel({ event }) {
   const registered = isRegistered(event.id)
   const cancellationAllowed = canCancelRegistration(event, registration)
   const selectedTicket = ticketOptions.find((ticket) => String(ticket.id || '') === String(selectedTicketTypeId)) || ticketOptions[0]
-  const showPurchaseForm = (!registered || buyingMore) && !isSoldOut
-  const selectedQuantity = Math.max(1, Number(quantity || 1))
-  const totalAmount = Number(selectedTicket?.price || 0) * selectedQuantity
-
   const maxCapacity = Number(event?.maximumParticipants) || 0
   const confirmedRegistrations = Number(event?.registrations) || 0
   const remaining = maxCapacity > 0 ? Math.max(0, maxCapacity - confirmedRegistrations) : null
   const isSoldOut = remaining !== null && remaining <= 0
   const isLowCapacity = remaining !== null && remaining > 0 && remaining <= 5
+  const showPurchaseForm = (!registered || buyingMore) && !isSoldOut
+  const selectedQuantity = Math.max(1, Number(quantity || 1))
+  const totalAmount = Number(selectedTicket?.price || 0) * selectedQuantity
 
   async function handleBookmark() {
     setBusy(true)
-- 
